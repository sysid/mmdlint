{
	"name": "@sysid/mmdlint",
	"version": "0.1.0",
	"type": "module",
	"description": "Validate Mermaid diagram syntax in Markdown, headless (no browser), via Mermaid's own parser.",
	"keywords": [
		"mermaid",
		"markdown",
		"lint",
		"validate",
		"cli",
		"diagram",
		"ci"
	],
	"license": "MIT",
	"author": "sysid <sysid@gmx.de>",
	"repository": {
		"type": "git",
		"url": "https://github.com/sysid/mmdlint"
	},
	"bugs": {
		"url": "https://github.com/sysid/mmdlint/issues"
	},
	"homepage": "https://github.com/sysid/mmdlint",
	"bin": {
		"mmdlint": "dist/cli.js"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"README.md",
		"VERSION"
	],
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"build": "tsc",
		"check": "biome check . && tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"jsdom": "^26.0.0",
		"mermaid": "^11.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/jsdom": "^21.1.7",
		"@types/node": "^22.10.5",
		"typescript": "^5.9.2",
		"vitest": "^4.1.8"
	}
}
